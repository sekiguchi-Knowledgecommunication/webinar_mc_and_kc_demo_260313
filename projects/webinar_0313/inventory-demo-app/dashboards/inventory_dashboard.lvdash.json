{
    "datasets": [
        {
            "name": "inventory_kpi",
            "displayName": "在庫KPI",
            "query": "SELECT\n  SUM(avg_inventory_value) as total_value,\n  COUNT(DISTINCT item_id) as total_items\nFROM apps_demo_catalog.webinar_demo_0313.inventory_summary\nWHERE month = (\n  SELECT MAX(month) FROM apps_demo_catalog.webinar_demo_0313.inventory_summary\n)"
        },
        {
            "name": "turnover_kpi",
            "displayName": "回転率KPI",
            "query": "SELECT\n  AVG(avg_turnover_rate) as avg_turnover\nFROM apps_demo_catalog.webinar_demo_0313.turnover_analysis"
        },
        {
            "name": "overstock_kpi",
            "displayName": "過剰在庫KPI",
            "query": "SELECT COUNT(DISTINCT item_id) as overstock_count\nFROM apps_demo_catalog.webinar_demo_0313.overstock_alert\nWHERE days_on_hand >= 90"
        },
        {
            "name": "inventory_trend",
            "displayName": "在庫推移",
            "query": "SELECT\n  month,\n  category,\n  SUM(avg_inventory_value) as avg_inventory_value\nFROM apps_demo_catalog.webinar_demo_0313.inventory_summary\nGROUP BY month, category\nORDER BY month, category"
        },
        {
            "name": "category_breakdown",
            "displayName": "カテゴリ別構成",
            "query": "SELECT\n  category,\n  SUM(avg_inventory_value) as total_value,\n  COUNT(DISTINCT item_id) as item_count\nFROM apps_demo_catalog.webinar_demo_0313.inventory_summary\nWHERE month = (\n  SELECT MAX(month) FROM apps_demo_catalog.webinar_demo_0313.inventory_summary\n)\nGROUP BY category\nORDER BY total_value DESC"
        },
        {
            "name": "overstock_alerts",
            "displayName": "過剰在庫アラート",
            "query": "SELECT\n  item_id,\n  item_name,\n  category,\n  turnover_rate,\n  days_on_hand,\n  avg_inventory_value\nFROM apps_demo_catalog.webinar_demo_0313.overstock_alert\nWHERE days_on_hand >= 60\nORDER BY days_on_hand DESC\nLIMIT 20"
        },
        {
            "name": "turnover_trend",
            "displayName": "回転率推移",
            "query": "SELECT\n  month,\n  category,\n  avg_turnover_rate\nFROM apps_demo_catalog.webinar_demo_0313.turnover_analysis\nORDER BY month, category"
        },
        {
            "name": "supplier_leadtime",
            "displayName": "サプライヤーリードタイム",
            "query": "SELECT\n  supplier_id,\n  AVG(lead_time_actual_days) as avg_lead_time\nFROM apps_demo_catalog.webinar_demo_0313.receipts\nGROUP BY supplier_id\nORDER BY avg_lead_time DESC\nLIMIT 15"
        }
    ],
    "pages": [
