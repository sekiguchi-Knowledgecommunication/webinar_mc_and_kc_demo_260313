{
  "datasets": [
    {
      "name": "inventory_kpi",
      "displayName": "在庫KPI",
      "queryLines": [
        "SELECT\n",
        "  SUM(avg_inventory_value) as total_value,\n",
        "  COUNT(DISTINCT item_id) as total_items\n",
        "FROM apps_demo_catalog.webinar_demo_0313.inventory_summary\n",
        "WHERE month = (\n",
        "  SELECT MAX(month) FROM apps_demo_catalog.webinar_demo_0313.inventory_summary\n",
        ")"
      ]
    },
    {
      "name": "turnover_kpi",
      "displayName": "回転率KPI",
      "queryLines": [
        "SELECT\n",
        "  AVG(avg_turnover_rate) as avg_turnover\n",
        "FROM apps_demo_catalog.webinar_demo_0313.turnover_analysis"
      ]
    },
    {
      "name": "overstock_kpi",
      "displayName": "過剰在庫KPI",
      "queryLines": [
        "SELECT COUNT(DISTINCT item_id) as overstock_count\n",
        "FROM apps_demo_catalog.webinar_demo_0313.overstock_alert\n",
        "WHERE days_on_hand >= 90"
      ]
    },
    {
      "name": "inventory_trend",
      "displayName": "在庫推移",
      "queryLines": [
        "SELECT\n",
        "  month,\n",
        "  category,\n",
        "  SUM(avg_inventory_value) as avg_inventory_value\n",
        "FROM apps_demo_catalog.webinar_demo_0313.inventory_summary\n",
        "GROUP BY month, category\n",
        "ORDER BY month, category"
      ]
    },
    {
      "name": "category_breakdown",
      "displayName": "カテゴリ別構成",
      "queryLines": [
        "SELECT\n",
        "  category,\n",
        "  SUM(avg_inventory_value) as total_value,\n",
        "  COUNT(DISTINCT item_id) as item_count\n",
        "FROM apps_demo_catalog.webinar_demo_0313.inventory_summary\n",
        "WHERE month = (\n",
        "  SELECT MAX(month) FROM apps_demo_catalog.webinar_demo_0313.inventory_summary\n",
        ")\n",
        "GROUP BY category\n",
        "ORDER BY total_value DESC"
      ]
    },
    {
      "name": "overstock_alerts",
      "displayName": "過剰在庫アラート",
      "queryLines": [
        "SELECT\n",
        "  item_id,\n",
        "  item_name,\n",
        "  category,\n",
        "  turnover_rate,\n",
        "  days_on_hand,\n",
        "  avg_inventory_value\n",
        "FROM apps_demo_catalog.webinar_demo_0313.overstock_alert\n",
        "WHERE days_on_hand >= 60\n",
        "ORDER BY days_on_hand DESC\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "turnover_trend",
      "displayName": "回転率推移",
      "queryLines": [
        "SELECT\n",
        "  month,\n",
        "  category,\n",
        "  avg_turnover_rate\n",
        "FROM apps_demo_catalog.webinar_demo_0313.turnover_analysis\n",
        "ORDER BY month, category"
      ]
    },
    {
      "name": "supplier_leadtime",
      "displayName": "サプライヤーリードタイム",
      "queryLines": [
        "SELECT\n",
        "  supplier_id,\n",
        "  AVG(lead_time_actual_days) as avg_lead_time\n",
        "FROM apps_demo_catalog.webinar_demo_0313.receipts\n",
        "GROUP BY supplier_id\n",
        "ORDER BY avg_lead_time DESC\n",
        "LIMIT 15"
      ]
    }
  ],
  "pages": [
